{
  "name": "lentera-pasar",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:api": "corepack pnpm --filter @lentera-pasar/api dev",
    "build:api": "corepack pnpm --filter @lentera-pasar/api build",
    "prisma:generate": "corepack pnpm --filter @lentera-pasar/api prisma:generate",
    "prisma:validate": "corepack pnpm --filter @lentera-pasar/api prisma:validate",
    "prisma:migrate": "corepack pnpm --filter @lentera-pasar/api prisma:migrate",
    "prisma:seed": "corepack pnpm --filter @lentera-pasar/api prisma:seed",
    "db:reset:keep-users": "corepack pnpm --filter @lentera-pasar/api db:reset:keep-users",
    "backfill:company-profile-structure": "corepack pnpm --filter @lentera-pasar/api backfill:company-profile-structure",
    "smoke:api": "corepack pnpm --filter @lentera-pasar/api smoke",
    "backfill:page-navigation": "corepack pnpm --filter @lentera-pasar/api backfill:page-navigation",
    "dev:site-renderer": "corepack pnpm --filter @lentera-pasar/site-renderer dev",
    "build:site-renderer": "corepack pnpm --filter @lentera-pasar/site-renderer build",
    "start:site-renderer": "corepack pnpm --filter @lentera-pasar/site-renderer start",
    "check:deployment": "corepack pnpm --filter @lentera-pasar/api check:deployment"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}

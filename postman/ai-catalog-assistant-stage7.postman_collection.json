          "name": "Simulator - Produk Tidak Ada / Handoff",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Created', function () { pm.expect(pm.response.code).to.eql(201); });",
                  "const json = pm.response.json();",
                  "if (json.conversation) pm.environment.set('conversationId', json.conversation.id);"

# NEXT_PUBLIC_API_BASE_URL: Base URL of the Lentera Pasar backend API (defaults to Port 4000).
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/api/v1"
# NEXT_PUBLIC_SITE_RENDERER_URL: Base URL of the site-renderer for section preview (defaults to Port 3001).
NEXT_PUBLIC_SITE_RENDERER_URL="http://localhost:3001"

{
  "name": "@lentera-pasar/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "tsx prisma/seed.ts",
    "backfill:company-profile-structure": "tsx scripts/backfill-company-profile-structure.ts",
    "db:reset:keep-users": "tsx scripts/reset-keep-users.ts",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:cleanup": "tsx scripts/smoke-cleanup.ts",
    "backfill:page-navigation": "tsx scripts/backfill-page-navigation.ts",
    "check:deployment": "tsx scripts/check-deployment.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@lentera-pasar/shared": "workspace:*",
    "@prisma/client": "^5.22.0",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "nodemailer": "^6.9.15",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.15",
    "@types/nodemailer": "^6.4.16",
    "prisma": "^5.22.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}

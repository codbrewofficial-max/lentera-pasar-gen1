# Lentera Pasar API Environment
# Mode values:
# - development: local coding/default
# - production: runtime production security mode
# - deployment: pre-deploy validation mode, same strictness as production
APP_MODE=development
NODE_ENV=development

DATABASE_URL="postgresql://lentera:lentera123@localhost:5432/lentera_pasar?schema=public"
API_PORT=4000

# SECURITY
# Production/deployment: minimum 32 chars, do not use this example value.
JWT_SECRET="change-this-dev-secret-minimum-32-chars"
JWT_EXPIRES_IN="7d"
IP_HASH_SECRET="change-this-ip-hash-secret-minimum-32-chars"

# Internal/deployment server-to-server API key.
# Used by /api/v1/health/ready and /api/v1/deployment/health via x-lentera-api-key.
# Production/deployment: minimum 32 chars, do not use this example value.
INTERNAL_API_KEY="change-this-internal-api-key-minimum-32-chars"

# CORS
# Production/deployment: explicit origins only, no wildcard.
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# OBSERVABILITY
LOG_LEVEL="debug"
LOG_PRETTY="true"

# LIMITS
REQUEST_BODY_LIMIT_BYTES=1048576
TEMPLATE_UPLOAD_MAX_BYTES=5242880

# RATE LIMITS
RATE_LIMIT_GLOBAL_MAX=180
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_CONTACT_MAX=8
RATE_LIMIT_TRACKING_MAX=120
RATE_LIMIT_TEMPLATE_UPLOAD_MAX=10
